# Public URL for canonical links, Open Graph, sitemap, and robots (no trailing slash).
# Required in production for correct SEO URLs.
# NEXT_PUBLIC_SITE_URL=https://www.example.com

# Optional: Google Search Console HTML tag verification value only (not the full tag).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=...

# Optional: Google Analytics 4 Measurement ID (layout defaults to G-19XWBZXT88 if unset).
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-19XWBZXT88

# Optional: AdSense client (ca-pub-…) — layout defaults to your publisher ID if unset.
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-7494206891190273
#
# Display ad unit slot IDs (numeric, from AdSense → Ads → By ad unit). Create one unit per
# placement, then paste each ID. Leave unset to hide that slot until units are ready.
# NEXT_PUBLIC_ADSENSE_SLOT_HOME_TOP=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_TOOL_INLINE=1234567890

# Used for the article pipeline, outlines, and the “Guide” section at the bottom of each tool page.
GEMINI_API_KEY=your_gemini_key_here
# Optional: preferred model (tried first; others still used if 429/404). Leave unset for default order.
# GEMINI_MODEL=gemini-2.0-flash
TAVILY_API_KEY=your_tavily_key_here
SERPER_API_KEY=your_serper_key_here

# Optional: Google Search Console — enables “Fetch Search Console queries” in the UI.
# Enable “Google Search Console API” in Google Cloud for the same project as the service account.
#
# Recommended: service account (no OAuth). Create a service account, download JSON, paste the
# entire JSON as a single line in Vercel (or use a multiline env). Add the service account
# email in Search Console → Settings → Users and permissions (Full or Owner).
# GSC_SITE_URL must match the property string in Search Console exactly (www vs non-www,
# https, trailing slash, or sc-domain:example.com for domain properties).
# GSC_SITE_URL=https://www.example.com/
# GSC_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
#
# Legacy: OAuth refresh token instead of service account.
# GSC_CLIENT_ID=
# GSC_CLIENT_SECRET=
# GSC_REFRESH_TOKEN=
