// PostgreSQL (Supabase, Neon, etc.). Use pooled URL for the app + direct URL for migrations.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Which site surface owns the URL: main product (AI/SEO) vs education subdomain.
enum SiteDomain {
  main
  education
}

model VisibilityLog {
  id           Int      @id @default(autoincrement())
  keyword      String
  domain       String
  model        String
  mentioned    Boolean
  position     Int?
  responseText String   @db.Text
  createdAt    DateTime @default(now())
}

model PromptQuery {
  id        Int      @id @default(autoincrement())
  query     String
  source    String
  createdAt DateTime @default(now())
}

model OptimizedContent {
  id               Int      @id @default(autoincrement())
  keyword          String
  originalContent  String   @db.Text
  optimizedContent String   @db.Text
  score            Int
  createdAt        DateTime @default(now())
}

model BlogPost {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String?    @db.Text
  content     String     @db.Text
  published   Boolean    @default(false)
  siteDomain  SiteDomain @default(main)
  authorEmail String
  authorName  String     @default("Harsh")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

/// Lead form submissions from /blogs/[slug] and /news/[slug].
model LeadInquiry {
  id            String   @id @default(cuid())
  source        String
  articleSlug   String
  articleTitle  String
  name          String
  email         String
  phone         String?
  message       String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([source, articleSlug])
}

/// Public share pages created from generated article output.
model SharedArticle {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  markdown    String     @db.Text
  html        String     @db.Text
  siteDomain  SiteDomain @default(main)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([createdAt])
}

// Sitemap-backed education news: persisted + optional AI repurposed draft (SEO-style).
model EducationNewsArticle {
  id                 String     @id @default(cuid())
  url                String     @unique
  title              String
  source             String
  lastmod            String
  siteDomain         SiteDomain @default(education)
  authorName         String     @default("Harsh")
  rawArticleText     String?   @db.Text
  rawFetchedAt       DateTime?
  repurposedMarkdown String?   @db.Text
  repurposedAt       DateTime?
  // URL on this site: /news/{repurposedSlug}; full URL stored for sharing / SEO.
  repurposedSlug          String? @unique
  repurposedCanonicalUrl  String?
  // Hero/OG image on images CDN (e.g. images.rankflowhq.com) after Vercel Blob upload.
  repurposedImageUrl String?
  // Optional board/exam logo URL for featured image template (left slot); see NEWS_FEATURED_EXAM_LOGO_URL fallback.
  examLogoUrl        String?
  // pending | processing | ready | error
  repurposeStatus    String    @default("pending")
  errorMessage       String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

/// App-side profile for Supabase Auth users (synced via API; keyed by Supabase user id).
model UserProfile {
  id               String   @id @default(cuid())
  /// `auth.users.id` from Supabase (UUID string).
  supabaseUserId   String   @unique
  email            String?
  displayName      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
