// PostgreSQL (Supabase, Neon, etc.). Use pooled URL for the app + direct URL for migrations.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Which site surface owns the URL: main product (AI/SEO) vs education subdomain.
enum SiteDomain {
  main
  education
}

model VisibilityLog {
  id           Int      @id @default(autoincrement())
  keyword      String
  domain       String
  model        String
  mentioned    Boolean
  position     Int?
  responseText String   @db.Text
  createdAt    DateTime @default(now())
}

model PromptQuery {
  id        Int      @id @default(autoincrement())
  query     String
  source    String
  createdAt DateTime @default(now())
}

model OptimizedContent {
  id               Int      @id @default(autoincrement())
  keyword          String
  originalContent  String   @db.Text
  optimizedContent String   @db.Text
  score            Int
  createdAt        DateTime @default(now())
}

model BlogPost {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String?    @db.Text
  content     String     @db.Text
  published   Boolean    @default(false)
  siteDomain  SiteDomain @default(main)
  authorEmail String
  authorName  String     @default("Harsh")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

/// Lead form submissions from /blogs/[slug] and /news/[slug].
model LeadInquiry {
  id            String   @id @default(cuid())
  source        String
  articleSlug   String
  articleTitle  String
  name          String
  email         String
  phone         String?
  message       String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([source, articleSlug])
}

/// Public share pages created from generated article output.
model SharedArticle {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  markdown    String     @db.Text
  html        String     @db.Text
  siteDomain  SiteDomain @default(main)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([createdAt])
}

// Sitemap-backed education news: persisted + optional AI repurposed draft (SEO-style).
model EducationNewsArticle {
  id                 String     @id @default(cuid())
  url                String     @unique
  title              String
  source             String
  lastmod            String
  siteDomain         SiteDomain @default(education)
  authorName         String     @default("Harsh")
  rawArticleText     String?   @db.Text
  rawFetchedAt       DateTime?
  repurposedMarkdown String?   @db.Text
  repurposedAt       DateTime?
  // URL on this site: /news/{repurposedSlug}; full URL stored for sharing / SEO.
  repurposedSlug          String? @unique
  repurposedCanonicalUrl  String?
  // Hero/OG image on images CDN (e.g. images.rankflowhq.com) after Vercel Blob upload.
  repurposedImageUrl String?
  // Optional board/exam logo URL for featured image template (left slot); see NEWS_FEATURED_EXAM_LOGO_URL fallback.
  examLogoUrl        String?
  // pending | processing | ready | error
  repurposeStatus    String    @default("pending")
  errorMessage       String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

/// App-side profile for Supabase Auth users (synced via API; keyed by Supabase user id).
model UserProfile {
  id               String   @id @default(cuid())
  /// `auth.users.id` from Supabase (UUID string).
  supabaseUserId   String   @unique
  email            String?
  displayName      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Per-user generation history for dashboard (Supabase-authenticated users).
model UserGeneratedArticle {
  id             String   @id @default(cuid())
  supabaseUserId String
  title          String
  topic          String
  primaryKeyword String?
  sourceUrl      String?
  markdown       String   @db.Text
  wordCount      Int      @default(0)
  createdAt      DateTime @default(now())

  keywords                 ArticleKeyword[]
  embedding                ArticleEmbedding?
  outgoingLinkSuggestions  InternalLinkSuggestion[] @relation("LinkFrom")
  incomingLinkSuggestions  InternalLinkSuggestion[] @relation("LinkTo")

  @@index([supabaseUserId, createdAt])
}

/// Keywords attached to a user-generated article (for clustering + internal linking).
enum KeywordRole {
  primary
  secondary
  supporting
}

model ArticleKeyword {
  id        String      @id @default(cuid())
  articleId String
  article   UserGeneratedArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  phrase    String
  role      KeywordRole @default(secondary)
  createdAt DateTime    @default(now())

  @@index([articleId])
  @@index([phrase])
}

/// Cached embedding vector (JSON float[]) for semantic similarity — avoids recomputing on every link pass.
model ArticleEmbedding {
  id         String   @id @default(cuid())
  articleId  String   @unique
  article    UserGeneratedArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  model      String
  dimensions Int
  vector     Json
  updatedAt  DateTime @updatedAt
}

/// Suggested internal link edge between two stored articles (optional persistence layer).
enum InternalLinkKind {
  same_cluster
  supporting_keyword
  parent_child
  semantic
}

model InternalLinkSuggestion {
  id            String           @id @default(cuid())
  fromArticleId String
  toArticleId   String
  fromArticle   UserGeneratedArticle @relation("LinkFrom", fields: [fromArticleId], references: [id], onDelete: Cascade)
  toArticle     UserGeneratedArticle @relation("LinkTo", fields: [toArticleId], references: [id], onDelete: Cascade)
  score         Float
  anchorText    String
  kind          InternalLinkKind
  rationale     String?          @db.Text
  appliedAt     DateTime?

  @@unique([fromArticleId, toArticleId])
  @@index([fromArticleId])
  @@index([toArticleId])
}

/// Social distribution batch: generated pack + schedule + post results (Twitter, LinkedIn, Pinterest).
enum DistributionBatchStatus {
  draft
  queued
  processing
  completed
  partial_failure
  failed
}

model DistributionBatch {
  id               String                  @id @default(cuid())
  supabaseUserId   String?
  /// Optional link to app content (e.g. UserGeneratedArticle id or shared slug).
  articleRef       String?
  canonicalUrl     String
  title            String
  summary          String?                 @db.Text
  packJson         Json
  scheduledAt      DateTime?
  status           DistributionBatchStatus @default(queued)
  resultJson       Json?
  lastError        String?                 @db.Text
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([status, scheduledAt])
  @@index([supabaseUserId, createdAt])
}

/// Snapshot from GSC feedback loop (metrics + suggestions) for auditing trends over time.
model SeoFeedbackSnapshot {
  id          String   @id @default(cuid())
  pageUrl     String
  payloadJson Json
  createdAt   DateTime @default(now())

  @@index([pageUrl, createdAt])
}
